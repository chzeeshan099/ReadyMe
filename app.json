{
  "expo": {
    "name": "ReadyMe",
    "slug": "readyme-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_name.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/logo_name.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#020712"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_name.jpeg",
        "backgroundColor": "#020712"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.readyme.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/logo_name.jpeg"
    },
    "extra": {
      "eas": {
        "projectId": "3b83706f-8a99-44ad-b6fd-8994a7b2bf05"
      }
    },
    "owner": "readyme"
  }
}
